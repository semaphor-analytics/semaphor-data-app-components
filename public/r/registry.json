      "description": "SDK-shaped loading, error, empty, partial, and stale-data boundary for Semaphor Data App query results.",
      "registryDependencies": ["alert", "badge", "button", "skeleton"],
      "files": [
        {
          "path": "registry/query-state-boundary/index.ts",
          "type": "registry:lib",
